@{
}
<div class="card mx-auto" style="width: 350px; margin-top: 50px;">
    <div class="card-body">
        <h4>Crear Cuenta</h4>
        <form action="/Login/Registrarse" method="post">
            <input type="text" name="Nombre" class="form-control mb-2" placeholder="Nombre Completo" required />
            <input type="email" name="Email" class="form-control mb-2" placeholder="Correo" required />
            <input type="password" name="PasswordHash" class="form-control mb-2" placeholder="Contraseña" required />
            <button class="btn btn-success w-100">Registrar</button>
        </form>
    </div>
</div>