@{
}
<div class="card mx-auto" style="width: 350px; margin-top: 50px;">
    <div class="card-body">
        <h4>Recuperar Acceso</h4>
        <form action="/Login/Recuperar" method="post">
            <p>Ingresa tu correo para recibir un token:</p>
            <input type="email" name="email" class="form-control mb-2" required />
            <button class="btn btn-warning w-100">Obtener Token</button>
        </form>

        @if (ViewBag.Mensaje != null)
        {
            <div class="alert alert-info mt-2">
                <strong>@ViewBag.Mensaje</strong>
                <hr />
                <a href="/Login/ResetPassword" class="btn btn-primary btn-sm w-100">Ir a cambiar contraseña</a>
            </div>
        }
    </div>
</div>